<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Madhuram | Start Your Own Cleaning Brand</title>
    <meta name="description" content="Launch your own cleaning product brand with Madhuram. Customize labels and order high-quality products today.">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; scroll-behavior: smooth; }
        .gradient-bg { background: linear-gradient(135deg, #eff6ff 0%, #ecfdf5 100%); }
        .label-preview-container { position: relative; width: 300px; height: 400px; margin: 0 auto; }
        #labelCanvas { border-radius: 8px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 100%; }
        .product-card:hover { transform: translateY(-5px); transition: all 0.3s ease; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="text-2xl font-bold text-blue-600">Madhuram</div>
                <div class="hidden md:flex space-x-8 font-medium">
                    <a href="#home" class="hover:text-blue-600">Home</a>
                    <a href="#features" class="hover:text-blue-600">Features</a>
                    <a href="#products" class="hover:text-blue-600">Products</a>
                </div>
                <a href="https://wa.me/91XXXXXXXXXX?text=Hello%20Madhuram,%20I%20want%20to%20start%20my%20own%20cleaning%20brand." 
                   class="bg-green-500 hover:bg-green-600 text-white px-5 py-2 rounded-full text-sm font-semibold transition">
                    WhatsApp Us
                </a>
            </div>
        </div>
    </nav>

    <section id="home" class="gradient-bg py-20 px-4">
        <div class="max-w-7xl mx-auto text-center">
            <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-6">
                Start Your Own <span class="text-blue-600">Cleaning Brand</span>
            </h1>
            <p class="text-lg md:text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
                Launch your own brand with Madhuram ready-to-sell products. High quality, low investment, and custom branding made easy.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="#generator" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-lg font-bold text-lg shadow-lg">
                    Create Your Brand Label
                </a>
                <a href="#products" class="bg-white hover:bg-gray-50 text-blue-600 border border-blue-200 px-8 py-4 rounded-lg font-bold text-lg">
                    Explore Products
                </a>
            </div>
        </div>
    </section>

    <section id="features" class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div class="p-6 text-center">
                    <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">💰</div>
                    <h3 class="font-bold text-xl mb-2">Low Investment</h3>
                    <p class="text-gray-500">Start your business without breaking the bank.</p>
                </div>
                <div class="p-6 text-center">
                    <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">📦</div>
                    <h3 class="font-bold text-xl mb-2">Ready to Sell</h3>
                    <p class="text-gray-500">Formulas tested and ready for the market.</p>
                </div>
                <div class="p-6 text-center">
                    <div class="w-16 h-16 bg-purple-100 text-purple-600 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">🎨</div>
                    <h3 class="font-bold text-xl mb-2">Custom Label</h3>
                    <p class="text-gray-500">Your brand name on every single bottle.</p>
                </div>
                <div class="p-6 text-center">
                    <div class="w-16 h-16 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">📱</div>
                    <h3 class="font-bold text-xl mb-2">WhatsApp Order</h3>
                    <p class="text-gray-500">Seamless ordering process via chat.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="products" class="py-20 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold mb-12">Our Premium Base Products</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 max-w-4xl mx-auto">
                <div class="bg-white rounded-2xl p-8 shadow-sm product-card border border-gray-100">
                    <img src="https://placehold.co/400x500/0047AB/white?text=Toilet+Cleaner+Bottle" alt="Toilet Cleaner" class="w-full h-64 object-contain mb-6 rounded-lg">
                    <h3 class="text-2xl font-bold mb-2 text-blue-800">Toilet Cleaner</h3>
                    <p class="text-gray-600 mb-6">Heavy-duty descaler and stain remover with premium fragrance.</p>
                    <button onclick="openGenerator('Toilet Cleaner')" class="w-full bg-blue-600 text-white font-bold py-3 rounded-lg hover:bg-blue-700">Customize Label</button>
                </div>
                <div class="bg-white rounded-2xl p-8 shadow-sm product-card border border-gray-100">
                    <img src="https://placehold.co/400x500/2E8B57/white?text=Liquid+Wash+Bottle" alt="Liquid Machine Wash" class="w-full h-64 object-contain mb-6 rounded-lg">
                    <h3 class="text-2xl font-bold mb-2 text-green-800">Liquid Machine Wash</h3>
                    <p class="text-gray-600 mb-6">Advanced fabric care formula for both top and front-load machines.</p>
                    <button onclick="openGenerator('Liquid Machine Wash')" class="w-full bg-green-600 text-white font-bold py-3 rounded-lg hover:bg-green-700">Customize Label</button>
                </div>
            </div>
        </div>
    </section>

    <section id="generator" class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-4">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold mb-4">AI Label Preview</h2>
                <p class="text-gray-600">See exactly how your brand will look on our bottles.</p>
            </div>
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                <div class="bg-gray-50 p-8 rounded-2xl border border-gray-200">
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-semibold mb-2">Your Brand Name</label>
                            <input type="text" id="brandName" placeholder="e.g. CleanPro" oninput="updatePreview()" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold mb-2">Tagline</label>
                            <input type="text" id="tagline" placeholder="e.g. Quality You Trust" oninput="updatePreview()" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold mb-2">Select Product</label>
                            <select id="productSelect" onchange="updatePreview()" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none">
                                <option value="Toilet Cleaner">Toilet Cleaner</option>
                                <option value="Liquid Machine Wash">Liquid Machine Wash</option>
                            </select>
                        </div>
                        <button onclick="downloadLabel()" class="w-full bg-gray-900 text-white font-bold py-4 rounded-lg flex items-center justify-center gap-2">
                            <span>📥</span> Download Label Image
                        </button>
                    </div>
                </div>

                <div class="flex flex-col items-center">
                    <div class="label-preview-container">
                        <canvas id="labelCanvas" width="600" height="800"></canvas>
                    </div>
                    <p class="mt-4 text-sm text-gray-400 italic text-center">Real-time Digital Mockup</p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 bg-blue-600 text-white text-center px-4">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to launch?</h2>
        <p class="mb-10 text-blue-100 max-w-xl mx-auto">Get your custom labeled products delivered to your doorstep and start selling within a week.</p>
        <a href="https://wa.me/91XXXXXXXXXX?text=Hello%20Madhuram,%20I%20want%20to%20start%20my%20own%20cleaning%20brand." 
           class="bg-green-500 hover:bg-green-400 text-white px-10 py-4 rounded-full font-bold text-xl shadow-2xl transition-all inline-block">
            Order Now on WhatsApp
        </a>
    </section>

    <footer class="py-10 border-t border-gray-200 text-center text-gray-500 text-sm">
        <p>&copy; 2026 Madhuram Products. custommadhuram.in | All Rights Reserved.</p>
    </footer>

    <script>
        const canvas = document.getElementById('labelCanvas');
        const ctx = canvas.getContext('2d');

        function updatePreview() {
            const brand = document.getElementById('brandName').value || "Your Brand";
            const tagline = document.getElementById('tagline').value || "Your Tagline Here";
            const product = document.getElementById('productSelect').value;

            // Set colors based on product
            const primaryColor = product === "Toilet Cleaner" ? "#1e40af" : "#065f46";
            const secondaryColor = product === "Toilet Cleaner" ? "#3b82f6" : "#10b981";

            // Clear Canvas
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // 1. Draw Bottle Background (Mockup)
            ctx.fillStyle = "#ffffff";
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            // 2. Draw Label Header
            ctx.fillStyle = primaryColor;
            ctx.fillRect(50, 50, 500, 150);

            // 3. Brand Name
            ctx.fillStyle = "#ffffff";
            ctx.font = "bold 60px Inter";
            ctx.textAlign = "center";
            ctx.fillText(brand.toUpperCase(), 300, 140);

            // 4. Tagline
            ctx.fillStyle = "#ffffff";
            ctx.font = "italic 24px Inter";
            ctx.fillText(tagline, 300, 180);

            // 5. Product Name Area
            ctx.fillStyle = "#f3f4f6";
            ctx.fillRect(50, 200, 500, 550);
            
            ctx.fillStyle = primaryColor;
            ctx.font = "bold 45px Inter";
            ctx.fillText(product, 300, 450);

            // 6. Decorative Elements
            ctx.strokeStyle = secondaryColor;
            ctx.lineWidth = 10;
            ctx.strokeRect(70, 70, 460, 660);

            // 7. Quality Seal Placeholder
            ctx.beginPath();
            ctx.arc(480, 650, 40, 0, Math.PI * 2);
            ctx.fillStyle = secondaryColor;
            ctx.fill();
            ctx.fillStyle = "#fff";
            ctx.font = "bold 12px Inter";
            ctx.fillText("PREMIUM", 480, 645);
            ctx.fillText("QUALITY", 480, 660);
        }

        function openGenerator(productType) {
            document.getElementById('productSelect').value = productType;
            updatePreview();
            document.getElementById('generator').scrollIntoView({ behavior: 'smooth' });
        }

        function downloadLabel() {
            const link = document.createElement('a');
            link.download = `Madhuram-Custom-Label.png`;
            link.href = canvas.toDataURL();
            link.click();
        }

        // Initialize preview on load
        window.onload = updatePreview;
    </script>
</body>
</html>
